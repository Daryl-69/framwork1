# ─────────────────────────────────────────────────────────────────────
# Resume Scanner — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to  .env  and fill in your real keys.
#   cp .env.example .env          (Linux / macOS)
#   copy .env.example .env        (Windows)
#
# ⚠️  NEVER commit the real .env file — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────

# LlamaParse — cloud PDF/image parser (https://cloud.llamaindex.ai)
LLAMA_CLOUD_API_KEY=YOUR_KEY_HERE

# Groq — LLM inference API (https://console.groq.com/keys)
GROQ_API_KEY=YOUR_KEY_HERE

# (Optional) Multiple Groq keys for data-generation scripts (comma-separated)
# GROQ_API_KEYS=key1,key2,key3

# Google Gemini — used by test scripts (https://aistudio.google.com/apikey)
GEMINI_API_KEY=YOUR_KEY_HERE
